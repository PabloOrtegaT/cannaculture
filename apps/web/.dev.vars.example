NEXTJS_ENV=development
STORE_PROFILE=plant-seeds
AUTH_SECRET=replace-with-long-random-string
AUTH_REFRESH_TOKEN_SECRET=replace-with-another-long-random-string
AUTH_ADMIN_REFRESH_TOKEN_SECRET=replace-with-admin-refresh-secret
APP_BASE_URL=http://storefront.lvh.me:3000
ADMIN_BASE_URL=http://admin.lvh.me:3000
AUTH_ACCESS_TTL_SECONDS=900
AUTH_REFRESH_IDLE_DAYS=30
AUTH_REFRESH_ABSOLUTE_DAYS=180
AUTH_ADMIN_REFRESH_IDLE_HOURS=8
AUTH_ADMIN_REFRESH_ABSOLUTE_DAYS=7
ADMIN_REQUIRE_CF_ACCESS=false
RESEND_API_KEY=
RESEND_FROM_EMAIL=Cannaculture <noreply@cannaculture.com.mx>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MOCK_PAYMENT_WEBHOOK_SECRET=
INVENTORY_SWEEPER_TOKEN=
AUTH_REFRESH_SWEEP_TOKEN=

# Observability destination (optional)
# Set to one of: "r2-logpush", "axiom", "baselime", or leave empty for dashboard-only.
TELEMETRY_DESTINATION=
# Ingest URL for Axiom / Baselime (required when TELEMETRY_DESTINATION is set)
TELEMETRY_INGEST_URL=
# Ingest token / API key for the chosen backend (required when TELEMETRY_DESTINATION is set)
TELEMETRY_INGEST_TOKEN=
