{
  "name": "cannaculture",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @cannaculture/web",
    "build": "npm run build --workspace @cannaculture/web",
    "start": "npm run start --workspace @cannaculture/web",
    "cf:preflight": "npm run cf:preflight --workspace @cannaculture/web",
    "cf:build": "npm run cf:build --workspace @cannaculture/web",
    "cf:preview": "npm run preview --workspace @cannaculture/web",
    "cf:deploy": "npm run deploy --workspace @cannaculture/web",
    "cf:typegen": "npm run cf-typegen --workspace @cannaculture/web",
    "db:generate": "npm run db:generate --workspace @cannaculture/web",
    "db:migrate:local": "npm run db:migrate:local --workspace @cannaculture/web",
    "db:migrate:remote": "npm run db:migrate:remote --workspace @cannaculture/web",
    "db:migrate:remote:preview": "npm run db:migrate:remote:preview --workspace @cannaculture/web",
    "db:seed": "npm run db:seed --workspace @cannaculture/web",
    "db:seed:remote": "npm run db:seed:remote --workspace @cannaculture/web",
    "db:seed:remote:preview": "npm run db:seed:remote:preview --workspace @cannaculture/web",
    "test:e2e": "npm run test:e2e --workspace @cannaculture/web",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/psl": "^1.1.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "prettier": "^3.6.2",
    "tailwindcss": "^4"
  },
  "dependencies": {
    "psl": "^1.15.0"
  }
}
